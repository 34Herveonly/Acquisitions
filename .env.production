# Server configuration
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Database Configuration - Neon Cloud
# Replace with your actual Neon Cloud database URL
# Example: postgres://username:password@ep-example-123456.us-east-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Production specific settings
ENABLE_LOGGING=true
DEBUG_MODE=false

# Security (set these in your deployment environment)
# JWT_SECRET=your-jwt-secret-here
# SESSION_SECRET=your-session-secret-here